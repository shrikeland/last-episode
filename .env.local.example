# Supabase — найти в Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# TMDB — получить на https://www.themoviedb.org/settings/api
# Без NEXT_PUBLIC_ — доступен только на сервере
TMDB_API_KEY=your-tmdb-api-key

# Supabase Service Role — НИКОГДА не передавать на клиент (без NEXT_PUBLIC_)
# Найти: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key